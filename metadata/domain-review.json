{
  "repo": "copper-move-search-flow",
  "language": "Elixir",
  "category": "Chess and game engines",
  "goal": "Build an Elixir toolkit that studies search behavior through capacity fixtures, with allocation and spill reports and bounded memory input sets.",
  "review_model": {
    "terms": [
      "position pressure",
      "move ordering",
      "search width",
      "endgame risk"
